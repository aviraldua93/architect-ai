{
  "name": "architect-ai",
  "version": "0.1.0.0",
  "description": "AI-powered study tool for Claude Certified Architect exam. The codebase IS the curriculum.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "architect-ai": "./src/cli/index.ts"
  },
  "scripts": {
    "start": "bun run src/cli/index.ts",
    "quiz": "bun run src/cli/index.ts quiz",
    "study": "bun run src/cli/index.ts study",
    "assess": "bun run src/cli/index.ts assess",
    "dev": "bun --watch run src/cli/index.ts",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "test:tier1": "npm run lint && npm run type-check",
    "test:tier2": "echo 'TODO: Implement tier2 E2E tests'",
    "test:tier3": "echo 'TODO: Implement tier3 LLM-as-judge evaluation'",
    "test": "npm run test:tier1"
  },
  "keywords": [
    "ai",
    "education",
    "certification",
    "aws",
    "claude",
    "agent",
    "study-tool"
  ],
  "author": "Fatima Al-Rashid",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "dotenv": "^16.0.0",
    "zod": "^3.25.76"
  }
}
