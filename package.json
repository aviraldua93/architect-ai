{
  "name": "architect-ai",
  "version": "0.1.0.0",
  "description": "AI-powered study tool for Claude Certified Architect exam. The codebase IS the curriculum.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "architect-ai": "./src/cli/index.ts"
  },
  "scripts": {
    "start": "tsx src/cli/index.ts",
    "quiz": "tsx src/cli/index.ts quiz",
    "study": "tsx src/cli/index.ts study",
    "assess": "tsx src/cli/index.ts assess",
    "dev": "tsx --watch src/cli/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "bun test test/tier1/",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "education",
    "certification",
    "aws",
    "claude",
    "agent",
    "study-tool"
  ],
  "author": "Fatima Al-Rashid",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "dotenv": "^16.0.0",
    "zod": "^3.25.76"
  }
}
