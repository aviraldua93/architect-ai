{
  "name": "architect-ai",
  "version": "0.1.0",
  "description": "AI-powered study tool for Claude Certified Architect exam. The codebase IS the curriculum.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "architect-ai": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "tsx src/cli/index.ts",
    "quiz": "tsx src/cli/index.ts quiz",
    "study": "tsx src/cli/index.ts study",
    "assess": "tsx src/cli/index.ts assess",
    "dashboard": "tsx src/cli/index.ts dashboard",
    "exam": "tsx src/cli/exam.ts",
    "dev": "tsx --watch src/cli/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "bun test test/tier1/",
    "lint": "eslint src/ test/ --ext .ts",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build",
    "prepack": "npm run build",
    "lint:fix": "eslint src/ test/ --ext .ts --fix",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aviraldua93/architect-ai.git"
  },
  "homepage": "https://github.com/aviraldua93/architect-ai#readme",
  "bugs": {
    "url": "https://github.com/aviraldua93/architect-ai/issues"
  },
  "keywords": [
    "ai",
    "education",
    "certification",
    "aws",
    "claude",
    "agent",
    "study-tool"
  ],
  "author": "Aviral Dua",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^8.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "zod": "^3.25.76"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix"
    ]
  }
}
